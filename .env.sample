POSTGRES_DB=home_assistant_watchdog
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

APP_PORT=8086
SPRING_PROFILES_ACTIVE=local
# could be false only when codex debugs and needs to acces app
APP_SECURITY_ENABLED=true
APP_LOG_LEVEL=INFO
APP_LOG_FILE=logs/home-assistant-watchdog.log
SESSION_COOKIE_SECURE=false
SERVER_SERVLET_SESSION_TIMEOUT=30m

APP_BUILD_COMMIT=unknown
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5433/home_assistant_watchdog
JDBC_DATABASE_USERNAME=watchdog
JDBC_DATABASE_PASSWORD=change-me
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=

WATCHDOG_MQTT_ENABLED=true
WATCHDOG_MQTT_BROKER_URI=tcp://core-mosquitto:1883
WATCHDOG_MQTT_USERNAME=addons
WATCHDOG_MQTT_PASSWORD=change-me
WATCHDOG_MQTT_CLIENT_ID=home-assistant-watchdog
WATCHDOG_MQTT_CONNECTION_TIMEOUT_SECONDS=10
WATCHDOG_MQTT_KEEP_ALIVE_SECONDS=30
WATCHDOG_MQTT_RECONNECT_DELAY_SECONDS=30
WATCHDOG_ZIGBEE2MQTT_BASE_TOPIC=zigbee2mqtt-2

WATCHDOG_HOME_ASSISTANT_ENABLED=true
WATCHDOG_HOME_ASSISTANT_BASE_URL=https://home-assistant.localdomain.bnowakowski.pl:8123
WATCHDOG_HOME_ASSISTANT_TOKEN=
WATCHDOG_HOME_ASSISTANT_CONNECT_TIMEOUT=3s
WATCHDOG_HOME_ASSISTANT_READ_TIMEOUT=10s
WATCHDOG_HOME_ASSISTANT_SKIP_CERTIFICATE_CHECKS=false
# Optional explicit service-call mapping for advanced Home Assistant fixes.
# WATCHDOG_HOME_ASSISTANT_SERVICE_CALLS_0_PROPERTY_PATH=state
# WATCHDOG_HOME_ASSISTANT_SERVICE_CALLS_0_ENTITY_ID=climate.bedroom
# WATCHDOG_HOME_ASSISTANT_SERVICE_CALLS_0_DESIRED_VALUE=heat
# WATCHDOG_HOME_ASSISTANT_SERVICE_CALLS_0_DOMAIN=climate
# WATCHDOG_HOME_ASSISTANT_SERVICE_CALLS_0_SERVICE=set_hvac_mode

APP_NOTIFICATIONS_ENABLED=false
# Generate with `openssl rand -base64 32`; keep stable after saving Pushover preferences.
APP_NOTIFICATIONS_PUSHOVER_USER_KEY_ENCRYPTION_SECRET=
APP_NOTIFICATIONS_PUSHOVER_APP_TOKEN=
APP_NOTIFICATIONS_PUSHOVER_BASE_URL=https://api.pushover.net
APP_NOTIFICATIONS_PUSHOVER_CONNECT_TIMEOUT=3s
APP_NOTIFICATIONS_PUSHOVER_READ_TIMEOUT=5s

WATCHDOG_CHECK_ENABLED=true
WATCHDOG_CHECK_SCHEDULED_ENABLED=true
WATCHDOG_CHECK_RUN_ON_STARTUP=true
WATCHDOG_CHECK_RUN_TIMEOUT=5m
WATCHDOG_CHECK_INTERVAL_SECONDS=300
WATCHDOG_PARAMETER_HISTORY_RETENTION_DAYS=365
WATCHDOG_PARAMETER_HISTORY_RECORD_UNCHANGED=false
WATCHDOG_PARAMETER_HISTORY_UNCHANGED_SAMPLE_SECONDS=86400

WATCHDOG_NOTIFICATION_DEFAULT_COOLDOWN_SECONDS=86400
WATCHDOG_FIX_DEFAULT_RETRY_COUNT=3
WATCHDOG_FIX_DEFAULT_RETRY_DELAY_SECONDS=60
WATCHDOG_FIX_DEFAULT_COOLDOWN_SECONDS=300
WATCHDOG_MISSING_PROPERTY_RETRY_COUNT=3
WATCHDOG_MISSING_PROPERTY_RETRY_DELAY_SECONDS=10
WATCHDOG_STALE_MAINS_SECONDS=7200
WATCHDOG_STALE_BATTERY_SECONDS=86400
WATCHDOG_STALE_CRITICAL_SECONDS=3600
